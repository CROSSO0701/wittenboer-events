# =====================================================================
# Wittenboer Events — environment variables
# Kopieer naar .env.local en vul in. Lege keys → integraties degraderen
# netjes (geen 500's, alleen logging in dev).
# =====================================================================

# --- Supabase ---
# Project URL en anon-key uit Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — alleen server-side gebruikt voor admin-acties
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional mail) ---
# https://resend.com/api-keys
RESEND_API_KEY=
# Adres waar admin-notificaties heen gaan
NOTIFY_ADMIN_EMAIL=info@wittenboerevents.nl

# --- Google Calendar (OAuth refresh-token flow) ---
# Marnix' eigen agenda. Volg /api/oauth/google/callback flow (komt later)
# om refresh-token op te halen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# E-mailadres of "primary" van de doel-agenda
GOOGLE_CALENDAR_ID=

# --- ArtwinLive iCal-feed ---
# Private feed-URL die ArtwinLive levert. Wordt elk kwartier via cron gesynced.
ARTWINLIVE_ICAL_URL=

# --- Cron (Vercel scheduled function) ---
# Random sterke string. Vercel cron stuurt: Authorization: Bearer $CRON_SECRET
CRON_SECRET=

# --- WhatsApp via CallMeBot (optioneel; staff-notificatie) ---
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_API_KEY=

# --- Lokalisatie ---
WITTENBOER_TIMEZONE=Europe/Amsterdam

# --- Site ---
# Voor links in mails. Zonder trailing slash.
NEXT_PUBLIC_SITE_URL=https://wittenboerevents.nl
